# ────────────────────────────────────────────────
#  .env 예시 — 이 파일을 복사해 `.env` 로 만들고 값을 채우세요.
#    cp .env.example .env
#  실제 .env 와 서비스계정 JSON 키는 절대 git 에 커밋하지 마세요 (.gitignore 처리됨).
# ────────────────────────────────────────────────

# ── GCP / BigQuery ──
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=finance_db
BQ_LOCATION=US
# 서비스계정 JSON 키 파일 경로 (예: credentials/ 폴더에 두기)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service_account.json

# ── FRED API (경제지표) ──
# 무료 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# ── Alpha Vantage (미국 주가) ──
# 무료 발급(즉시, 이메일만): https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your-alphavantage-key

# ── 로깅 ──
LOG_LEVEL=INFO
